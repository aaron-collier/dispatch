<aside class="dispatch-sidebar">
  <div class="dispatch-sidebar__inner">
    <%# Logo -%>
    <a href="/" class="dispatch-sidebar__logo text-decoration-none">
      <div class="dispatch-sidebar__logo-mark">D</div>
      <span class="dispatch-sidebar__logo-text fw-bold" style="font-size: 0.9375rem; color: var(--dispatch-text-primary);">
        <span style="color: var(--dispatch-purple);">DIS</span><span style="color: var(--dispatch-text-muted);">PATCH</span>
      </span>
    </a>

    <%# Nav sections -%>
    <nav aria-label="Main navigation">
      <% nav_sections.each do |section| %>
        <span class="dispatch-section-header dispatch-sidebar__label"><%= section[:label] %></span>
        <ul class="list-unstyled mb-0">
          <% section[:items].each do |item| %>
            <li>
              <a href="<%= item[:path] %>"
                 class="dispatch-sidebar__nav-link <%= 'active' if item[:active] %>">
                <i class="bi <%= item[:icon] %>"></i>
                <span class="dispatch-sidebar__label"><%= item[:label] %></span>
              </a>
            </li>
          <% end %>
        </ul>
      <% end %>
    </nav>

    <%# Spacer -%>
    <div class="flex-grow-1"></div>

    <%# Theme toggle -%>
    <div class="dispatch-theme-toggle">
      <i class="bi bi-moon-stars" style="font-size: 0.75rem; color: var(--dispatch-text-muted);"></i>
      <div class="form-check form-switch mb-0 ms-1">
        <input class="form-check-input"
               type="checkbox"
               role="switch"
               id="theme-toggle"
               data-theme-toggle
               data-action="change->theme#toggle"
               aria-label="Toggle light/dark mode">
        <label class="form-check-label" for="theme-toggle" style="font-size: 0.75rem; color: var(--dispatch-text-muted);">Light</label>
      </div>
    </div>

    <%# User profile -%>
    <div class="dispatch-sidebar__user">
      <% if user.github_profile_url %>
        <a href="<%= user.github_profile_url %>" target="_blank" rel="noopener noreferrer" class="text-decoration-none flex-shrink-0" aria-label="<%= user.name %> on GitHub">
          <% if user.avatar_url %>
            <img src="<%= user.avatar_url %>" alt="<%= user.name %>"
                 class="dispatch-sidebar__avatar"
                 style="border-radius: 50%; width: 28px; height: 28px; object-fit: cover;">
          <% else %>
            <div class="dispatch-sidebar__avatar"><%= user.initials %></div>
          <% end %>
        </a>
      <% else %>
        <% if user.avatar_url %>
          <img src="<%= user.avatar_url %>" alt="<%= user.name %>"
               class="dispatch-sidebar__avatar flex-shrink-0"
               style="border-radius: 50%; width: 28px; height: 28px; object-fit: cover;">
        <% else %>
          <div class="dispatch-sidebar__avatar flex-shrink-0"><%= user.initials %></div>
        <% end %>
      <% end %>

      <div class="dispatch-sidebar__user-info min-w-0">
        <% if user.github_profile_url %>
          <a href="<%= user.github_profile_url %>" target="_blank" rel="noopener noreferrer"
             class="text-decoration-none"
             style="font-size: 0.8125rem; font-weight: 600; color: var(--dispatch-text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block;">
            <%= user.name %>
          </a>
        <% else %>
          <div style="font-size: 0.8125rem; font-weight: 600; color: var(--dispatch-text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            <%= user.name %>
          </div>
        <% end %>
        <div style="font-size: 0.6875rem; color: var(--dispatch-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
          <%= user.email %>
        </div>
      </div>
    </div>
  </div>
</aside>
