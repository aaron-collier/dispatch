<div id="auth_indicator" class="dispatch-system-indicator">
  <span class="dispatch-system-indicator__dot" style="background-color: <%= status_color %>;"></span>
  <span class="dispatch-system-indicator__label">2FA Auth</span>
  <% if authenticated %>
    <span class="dispatch-system-indicator__status" style="color: <%= status_color %>;"><%= status_text %></span>
  <% else %>
    <%= link_to status_text, new_auth_path,
          class: "dispatch-system-indicator__status",
          style: "color: #{status_color}; text-decoration: underline;" %>
  <% end %>
</div>
