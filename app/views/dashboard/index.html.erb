<%# Mobile header — hamburger, visible < 768px only %>
<div class="dispatch-mobile-header" data-controller="sidebar">
  <button class="btn btn-link p-0 text-decoration-none"
          data-action="click->sidebar#open"
          aria-label="Open navigation">
    <i class="bi bi-list" style="font-size: 1.25rem; color: var(--dispatch-text-primary);"></i>
  </button>
  <span class="ms-3 fw-semibold" style="color: var(--dispatch-text-primary); font-size: 0.9375rem;">Dispatch</span>

  <%# Bootstrap Offcanvas drawer for mobile %>
  <div class="offcanvas offcanvas-start"
       id="sidebar-drawer"
       data-sidebar-target="drawer"
       style="width: 220px; background-color: var(--dispatch-sidebar-bg); border-right: 1px solid var(--dispatch-card-border);"
       tabindex="-1"
       aria-labelledby="sidebar-drawer-label">
    <div class="offcanvas-body p-0">
      <%= render Dashboard::SidebarComponent.new(user: @user, active_path: "/") %>
    </div>
  </div>
</div>

<%# Main layout wrapper %>
<div class="dispatch-root">
  <%# Desktop / tablet sidebar %>
  <%= render Dashboard::SidebarComponent.new(user: @user) %>

  <%# Scrollable content area %>
  <main class="dispatch-content">
    <%= turbo_stream_from "system_status" %>
    <%= turbo_stream_from "dependency_updates" %>
    <%= turbo_stream_from "integration_tests" %>

    <%# ── System indicators ───────────────────────────────── %>
    <div class="dispatch-system-indicators mb-3">
      <%= render Dashboard::SystemIndicatorComponent.new(
        key:          "vpn",
        label:        "VPN",
        connected:    @system_statuses["vpn"]&.connected || false,
        status:       @system_statuses["vpn"]&.status || "disconnected",
        connect_path: connect_vpn_path
      ) %>
      <%= render Dashboard::SystemIndicatorComponent.new(
        key:            "control_master",
        label:          "Control Master",
        connected:      @system_statuses["control_master"]&.connected || false,
        status:         @system_statuses["control_master"]&.status || "disconnected",
        connect_path:   connect_control_master_path,
        disconnect_path: disconnect_control_master_path
      ) %>
    </div>

    <%# ── Row 1: Stat cards (3-up) ───────────────────────── %>
    <div class="row g-3 mb-3">
      <%# First slot: live Dependency Updates card %>
      <div class="col-12 col-sm-6 col-lg-4">
        <%= render Dashboard::DependencyUpdateCardComponent.new(
          open_count:       @dependency_card[:open_count],
          passing:          @dependency_card[:passing],
          building:         @dependency_card[:building],
          failing:          @dependency_card[:failing],
          all_merged:       @dependency_card[:all_merged],
          merge_all_path:   merge_all_dependency_updates_path,
          release_all_path: release_all_dependency_updates_path
        ) %>
      </div>

      <%# Remaining stat cards from presenter %>
      <% @presenter.stat_cards.each do |card| %>
        <div class="col-12 col-sm-6 col-lg-4">
          <%= render Dashboard::StatCardComponent.new(
            label:           card.label,
            value:           card.value,
            delta:           card.delta,
            delta_direction: card.delta_direction,
            sparkline_data:  card.sparkline_data
          ) %>
        </div>
      <% end %>
    </div>

    <%# ── Row 2: Stability | Activity ─────────────────────── %>
    <div class="row g-3 mb-3">
      <div class="col-12 col-lg-6">
        <div class="dispatch-card h-100">
          <div class="dispatch-card__header">
            <span class="dispatch-label">Stability Overview</span>
            <div class="d-flex align-items-center gap-2">
              <%= render Dashboard::FilterPillComponent.new(
                options:     @stats.period_options,
                selected:    @stats.selected_period_label,
                link_param:  "stability_period",
                base_path:   root_path,
                turbo_frame: "stability-panel"
              ) %>
              <span id="run-tests-btn">
                <%= link_to "RUN TESTS", run_integration_tests_path,
                    data: { turbo_method: :post },
                    style: "font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.04em; color: var(--dispatch-dora-elite); border: 1px solid var(--dispatch-dora-elite); border-radius: 4px; padding: 2px 8px; text-decoration: none;" %>
              </span>
            </div>
          </div>
          <div class="dispatch-card__body">
            <%= turbo_frame_tag "stability-panel" do %>
              <%= render Dashboard::HealthScoreComponent.new(
                score:    @stats.health_score[:score],
                label:    @stats.health_score[:label],
                segments: @stats.health_segments
              ) %>
              <div class="mt-3">
                <%= render Dashboard::DataTableComponent.new(rows: @stats.test_rows) %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-6">
        <%= render Dashboard::PanelCardComponent.new(title: "Dependency Updates") do |c| %>
          <% c.with_body do %>
            <%= render Dashboard::DependencyUpdateFeedComponent.new(rows: @dependency_updates_feed) %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# ── Row 3: Charts ────────────────────────────────────── %>
    <div class="row g-3 mb-3">
      <div class="col-12 col-lg-8">
        <%= render Dashboard::PanelCardComponent.new(
          title:          "Deployment Cadence",
          filter_options: [ "Last 6 Months", "Last 3 Months", "Last Year" ]
        ) do |c| %>
          <% c.with_body do %>
            <%= render Dashboard::LineChartComponent.new(data: @presenter.line_chart_data) %>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-lg-4">
        <%= render Dashboard::PanelCardComponent.new(title: "Test Suite Health") do |c| %>
          <% c.with_body do %>
            <%= render Dashboard::DonutChartComponent.new(slices: @presenter.donut_chart_data) %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# ── Row 4: DORA metrics (4-up) ──────────────────────── %>
    <div class="row g-3 mb-3">
      <% @presenter.dora_metrics.each do |metric| %>
        <div class="col-12 col-sm-6 col-xl-3">
          <%= render Dashboard::DoraCardComponent.new(
            label: metric.label,
            value: metric.value,
            unit:  metric.unit,
            tier:  metric.tier,
            icon:  metric.icon
          ) %>
        </div>
      <% end %>
    </div>

  </main>
</div>
