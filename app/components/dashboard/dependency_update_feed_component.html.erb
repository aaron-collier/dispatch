<div id="dependency_update_feed">
  <% rows.each do |row| %>
    <div class="dispatch-feed__item">
      <div class="dispatch-feed__icon">
        <i class="bi bi-git" style="color: <%= icon_color_for(row.pr_state) %>;"></i>
      </div>
      <div class="dispatch-feed__message" title="<%= row.repo_name %>">
        <% if row.pr_url %>
          <%= link_to short_name(row.repo_name), row.pr_url,
                target: "_blank",
                rel: "noopener noreferrer",
                style: "color: inherit; text-decoration: none;" %>
        <% else %>
          <%= short_name(row.repo_name) %>
        <% end %>
        <% if row.release_tag.present? %>
          <span style="color: var(--dispatch-purple-light); font-size: 0.75rem;">(<%= row.release_tag %>)</span>
        <% end %>
      </div>
      <div class="dispatch-feed__meta d-flex gap-1 align-items-center">
        <% light_colors_for(row.pr_state).each do |color| %>
          <i class="bi bi-circle-fill" style="color: <%= color %>; font-size: 0.65rem;"></i>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
