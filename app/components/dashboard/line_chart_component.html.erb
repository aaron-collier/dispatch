<div class="dispatch-line-chart">
  <svg viewBox="0 0 800 180" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <linearGradient id="<%= gradient_id %>" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="<%= color %>" stop-opacity="0.25"/>
        <stop offset="100%" stop-color="<%= color %>" stop-opacity="0"/>
      </linearGradient>
    </defs>

    <%# Horizontal grid lines -%>
    <% [ 30, 60, 90, 120 ].each do |y| %>
      <line x1="16" y1="<%= y %>" x2="784" y2="<%= y %>"
            stroke="var(--dispatch-card-border)" stroke-width="1" stroke-opacity="0.4"/>
    <% end %>

    <%# Gradient fill area -%>
    <% unless fill_d.empty? %>
      <path class="dispatch-line-chart__fill" d="<%= fill_d %>"
            fill="url(#<%= gradient_id %>)"/>
    <% end %>

    <%# Stroke line -%>
    <% unless path_d.empty? %>
      <path class="dispatch-line-chart__stroke" d="<%= path_d %>"
            fill="none"
            stroke="<%= color %>"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"/>
    <% end %>

    <%# X-axis labels -%>
    <% data.each_with_index do |point, i| %>
      <% pts = path_points %>
      <% x = pts[i]&.first || 0 %>
      <text x="<%= x %>" y="172"
            text-anchor="middle"
            font-size="11"
            fill="var(--dispatch-text-muted)">
        <%= point.label %>
      </text>
    <% end %>
  </svg>
</div>
