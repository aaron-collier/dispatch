<div id="integration_tests_table" style="overflow-x: auto;">
  <table class="dispatch-table">
    <thead>
      <tr>
        <th style="text-align: left;">Test</th>
        <th style="text-align: left;">Status</th>
        <th style="text-align: right;">Fail Rate</th>
        <th style="text-align: right;">Last Run</th>
      </tr>
    </thead>
    <tbody>
      <% rows.each do |row| %>
        <tr>
          <td>
            <% test = tests[row.name] %>
            <% if test %>
              <%= link_to row.name.upcase, integration_test_path(test),
                  class: "dispatch-table__name font-mono",
                  style: "text-decoration: none; color: inherit;",
                  data: { turbo_frame: "_top" } %>
            <% else %>
              <span class="dispatch-table__name font-mono"><%= row.name %></span>
            <% end %>
          </td>
          <td>
            <% if row.status.present? %>
              <% status_color = { "queuing" => "var(--dispatch-text-muted)", "running" => "var(--dispatch-info)",
                                  "passed"  => "var(--dispatch-success)",   "failed"  => "var(--dispatch-danger)" }
                                .fetch(row.status.to_s, "var(--dispatch-text-muted)") %>
              <span class="badge" style="background-color: var(--dispatch-card-bg-elevated); color: <%= status_color %>; font-size: 0.6875rem; font-weight: 400;">
                <%= row.status.upcase %>
              </span>
            <% else %>
              <span class="dispatch-table__muted">—</span>
            <% end %>
          </td>
          <td style="text-align: right;">
            <% if row.fail_rate.present? %>
              <% fail_color = if row.fail_rate == 0.0
                                 "var(--dispatch-success)"
                               elsif row.fail_rate == 100.0
                                 "var(--dispatch-danger)"
                               else
                                 "var(--dispatch-warning)"
                               end %>
              <span style="color: <%= fail_color %>; font-size: 0.8125rem;"><%= "#{row.fail_rate}%" %></span>
            <% else %>
              <span class="dispatch-table__muted">—</span>
            <% end %>
          </td>
          <td class="dispatch-table__muted" style="text-align: right;">
            <%= row.last_run.presence || "—" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
