<%# Auth page — Shibboleth authentication required for integration tests %>
<div class="dispatch-root">
  <main class="dispatch-content d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="dispatch-card" style="max-width: 480px; width: 100%;">
      <div class="dispatch-card__header">
        <span class="dispatch-label">Authentication Required</span>
      </div>
      <div class="dispatch-card__body">
        <p style="color: var(--dispatch-text-secondary); margin-bottom: 1.5rem;">
          Integration tests require an active Shibboleth session. Click below to authenticate,
          then return here and confirm.
        </p>

        <a href="<%= Settings.auth.url %>"
           target="_blank"
           rel="noopener noreferrer"
           class="btn btn-primary w-100 mb-3">
          <i class="bi bi-box-arrow-up-right me-2"></i>
          Authenticate via Shibboleth
        </a>

        <%= form_with url: auth_path, method: :post do |f| %>
          <%= f.submit "I've authenticated — mark as active",
                class: "btn btn-success w-100" %>
        <% end %>

        <div class="mt-3 text-center">
          <%= link_to "← Back to dashboard", root_path,
                style: "color: var(--dispatch-text-muted); font-size: 0.875rem;" %>
        </div>
      </div>
    </div>
  </main>
</div>
