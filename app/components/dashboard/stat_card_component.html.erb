<div class="dispatch-card p-3 h-100">
  <div class="d-flex align-items-start justify-content-between gap-3">
    <div class="flex-grow-1 min-w-0">
      <div class="dispatch-label mb-2">
        <%= label %>
        <i class="bi bi-info-circle ms-1" style="font-size: 0.625rem;"></i>
      </div>
      <div class="dispatch-stat-value mb-1"><%= value %></div>
      <div class="d-flex align-items-center gap-1 flex-wrap">
        <span class="dispatch-delta dispatch-delta--<%= delta_direction %>">
          <%= trend_icon %> <%= delta %>
        </span>
        <span style="font-size: 0.75rem; color: var(--dispatch-text-muted);">than last month</span>
      </div>
    </div>

    <% unless sparkline_data.empty? %>
      <svg class="dispatch-sparkline flex-shrink-0" viewBox="0 0 80 40" width="80" height="40" aria-hidden="true">
        <polyline
          class="sparkline-path"
          points="<%= sparkline_points %>"
          fill="none"
          stroke="<%= trend_color %>"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    <% end %>
  </div>
</div>
